# Required
POSTER_ADMIN_PASSWORD=change-me
POSTER_REQUIRE_ADMIN_PASSWORD=false
POSTER_LOCAL_PORT=2004

# Bluesky
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Mastodon
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=
MASTODON_VISIBILITY=public

# Dev.to
DEVTO_API_KEY=
DEVTO_TAGS=indiehackers,webdev
DEVTO_DRAFT=false

# LinkedIn
# Use urn:li:person:... for a profile or urn:li:organization:... for a page.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_VERSION=202605

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
META_GRAPH_VERSION=v23.0

# Pinterest
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# Twitch chat message
# Token needs user:write:chat for the sender account.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REFRESH_TOKEN=
TWITCH_BROADCASTER_ID=
TWITCH_SENDER_ID=
TWITCH_CHANNEL_LOGIN=

# YouTube video upload
# OAuth token needs https://www.googleapis.com/auth/youtube.upload.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CATEGORY_ID=22
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_NOTIFY_SUBSCRIBERS=false
YOUTUBE_MADE_FOR_KIDS=false
YOUTUBE_TAGS=
