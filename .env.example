# Required
POSTER_ADMIN_PASSWORD=change-me
POSTER_REQUIRE_ADMIN_PASSWORD=false
POSTER_LOCAL_PORT=2004

# X / Twitter
X_BIRD_COMMAND=bird
X_BIRD_COOKIE_SOURCE=
X_BIRD_CHROME_PROFILE=
X_BIRD_FIREFOX_PROFILE=
X_BIRD_TIMEOUT_MS=60000
X_PREMIUM_LONG_POSTS=false

# LinkedIn
# Use urn:li:person:... for a profile or urn:li:organization:... for a page.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_SCOPES=openid profile w_member_social
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_VERSION=202605

# Bluesky
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Mastodon
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=
MASTODON_VISIBILITY=public

# Instagram
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_FILE=.instagram-sessions/account.json
INSTAGRAM_2FA_CODE=
INSTAGRAM_PYTHON_COMMAND=
INSTAGRAM_TIMEOUT_MS=300000

# YouTube
YOUTUBE_COOKIE_SOURCE=chrome
YOUTUBE_CHROME_PROFILE=Default
YOUTUBE_COOKIE=
YOUTUBE_PRIVACY=PUBLIC
YOUTUBE_TIMEOUT_MS=900000

# Dev.to
DEVTO_API_KEY=
DEVTO_TAGS=indiehackers,webdev
DEVTO_DRAFT=false

# Pinterest
PINTEREST_EMAIL=
PINTEREST_PASSWORD=
PINTEREST_USERNAME=
PINTEREST_BOARD_ID=
PINTEREST_CRED_ROOT=.pinterest-sessions/default
PINTEREST_SECTION_ID=
PINTEREST_ALT_TEXT=
PINTEREST_PYTHON_COMMAND=
PINTEREST_TIMEOUT_MS=300000
PINTEREST_HEADLESS=true

# Peerlist
PEERLIST_CONTEXT=SHOW
PEERLIST_USERNAME=
PEERLIST_CHROME_PROFILE=Default
PEERLIST_TIMEOUT_MS=120000

# Hacker News
# Unofficial personal automation through HN's normal login/submit form flow.
HACKERNEWS_USERNAME=
HACKERNEWS_PASSWORD=
HACKERNEWS_COOKIE=

# Nostr
# Use a dedicated nsec... or 64-character hex private key.
NOSTR_PRIVATE_KEY=
NOSTR_RELAYS=

# Dribbble
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=
DRIBBBLE_OAUTH_SCOPES=public upload
DRIBBBLE_ACCESS_TOKEN=
DRIBBBLE_TAGS=
DRIBBBLE_TEAM_ID=
DRIBBBLE_LOW_PROFILE=false
