# Required
POSTER_ADMIN_PASSWORD=change-me

# Bluesky
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Mastodon
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=
MASTODON_VISIBILITY=public

# Dev.to
DEVTO_API_KEY=
